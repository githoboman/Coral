# ============================================================================
#  CORAL — FRONTEND ENV (Vercel)
#  Copy to app/.env and fill the values. NEVER commit the filled file.
#  Note: only VITE_* vars are exposed to the browser.
# ============================================================================

# ── REQUIRED ────────────────────────────────────────────────────────────────
# Your deployed backend URL (the Render service).
VITE_API_BASE_URL=https://your-backend.onrender.com
VITE_SUI_NETWORK=testnet
# The agent's DeepBook BalanceManager object id (its trading account).
VITE_AGENT_BALANCE_MANAGER=0x...
VITE_MAINTENANCE_MODE=false

# ── OPTIONAL: Google / zkLogin sign-in (Enoki) ──────────────────────────────
# Leave blank to use wallet-extension sign-in only (works without these).
VITE_ENOKI_API_KEY=
VITE_GOOGLE_CLIENT_ID=

# ── LOCAL DEV ONLY — DO NOT set in production ───────────────────────────────
# Sends the connected address as x-dev-wallet so the backend dev-auth accepts it.
# VITE_AGENT_DEV_AUTH=true

# ============================================================================
#  LEGACY (Tovira features Coral does not use). Leave unset for the agent demo.
# ============================================================================
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
# VITE_SUI_PACKAGE_ID=
# VITE_SUI_BADGE_PACKAGE_ID=
# VITE_BADGE_REGISTRY_ID=
# VITE_SUI_SUBSCRIPTION_REGISTRY_ID=
# VITE_ETH_RPC_URL=
# VITE_SOLANA_RPC_URL=
# VITE_ENABLE_ONBOARDING=false
