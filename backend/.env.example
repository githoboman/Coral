# === TELEGRAM BOT CONFIG ===
TELEGRAM_BOT_TOKEN="your-telegram-bot-token-here"
BOT_USERNAME="your-telegram-bot-username"

# === GEMINI AI AGENT ===
GEMINI_API_KEY="your-gemini-api-key-here"
# Example usage: agent = ToviraAgent(GEMINI_API_KEY)

# === SUPABASE DATABASE ===
SUPABASE_URL="https://your-supabase-project-url.supabase.co"
SUPABASE_KEY="your-supabase-service-key"

# === EMAIL SETTINGS ===
EMAIL_USER="your-email@example.com"
EMAIL_PASSWORD="your-email-password-or-app-password"

# === REDIS (for production caching) ===
REDIS_URL="redis://your-redis-host:6379"
REDIS_PASSWORD="your-redis-password"

# === RATE LIMITING ===
RATE_LIMIT_ENABLED=true
MAX_REQUESTS_PER_MINUTE=60

# === SECURITY ===
SECRET_KEY="your-random-secret-key"
ALLOWED_ORIGINS=["https://tovira.xyz","https://www.tovira.xyz"]

# === EXTERNAL APIs (optional but recommended) ===
COINGECKO_API_KEY="your-coingecko-api-key"

# === GOOGLE OAUTH (for zkLogin) ===
GOOGLE_CLIENT_ID="your-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:5173/auth/callback"

# === ZKLOGIN CONFIGURATION ===
ZKLOGIN_SALT_SERVICE_URL="https://salt.api.mystenlabs.com/get_salt"
ZKLOGIN_PROVER_URL="https://prover-dev.mystenlabs.com/v1"