# ============================================================================
#  CORAL — BACKEND ENV (Render)
#  Copy to server/.env and fill the values. NEVER commit the filled file.
# ============================================================================

# ── REQUIRED: core server ───────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Your deployed frontend URL (comma-separate if more than one).
CORS_ORIGIN=https://your-frontend.vercel.app

# ── REQUIRED: auth + encryption ─────────────────────────────────────────────
# Random 48+ char string. Generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
TOKEN_HMAC_SECRET=replace_with_a_long_random_secret_at_least_48_chars
TOKEN_EXPIRES_DAYS=7
# base64 of 32 random bytes. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
ENCRYPTION_MASTER_KEY=replace_with_base64_32_byte_key

# ── REQUIRED: agent wallet (Sui testnet) ────────────────────────────────────
SUI_NETWORK=testnet
# Published agent_policy Move package.
AGENT_POLICY_PACKAGE_ID=0x...
# DeepBook V3 testnet package.
DEEPBOOK_PACKAGE_ID=0x...
# The agent's own private key (suiprivkey1...) so the server signs as that agent.
AGENT_IMPORT_KEY=suiprivkey1...

# ── RECOMMENDED ─────────────────────────────────────────────────────────────
# Real Gemini key for richer NL parsing. Without it, a regex fallback is used.
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash
# Pre-bind an existing policy+capability on boot (else create one live in the UI).
AGENT_IMPORT_POLICY_ID=
AGENT_IMPORT_CAPABILITY_ID=
# Override only if the demo pool uses a non-default USDC coin type.
# USDC_TYPE=0x...::usdc::USDC

# ── OPTIONAL: Walrus intent archiving (fails gracefully if unset) ────────────
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
WALRUS_EPOCHS=5

# ── LOCAL DEV ONLY — DO NOT set in production ───────────────────────────────
# Auth bypass for local testing (trusts an x-dev-wallet header). Never in prod.
# AGENT_DEV_AUTH=true

# ============================================================================
#  LEGACY (Tovira features Coral does not use). Leave unset for the agent demo.
#  Set only if you intentionally keep points / subscription / bridge / telegram
#  / email / profile-persistence routes enabled.
# ============================================================================
# SUPABASE_URL=
# SUPABASE_KEY=
# BLOCKVISION_API_KEY=
# TELEGRAM_BOT_TOKEN=
# EMAIL_USER=
# EMAIL_PASSWORD=
# SMTP_HOST=
# SMTP_PORT=
